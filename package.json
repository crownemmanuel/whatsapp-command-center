{
  "name": "whatsapp-command-center",
  "version": "0.1.1",
  "type": "module",
  "description": "Big-screen WhatsApp command center dashboard",
  "keywords": [
    "whatsapp",
    "dashboard",
    "baileys",
    "command-center",
    "monitoring"
  ],
  "license": "MIT",
  "author": "",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/your-username/whatsapp-command-center.git"
  },
  "bugs": {
    "url": "https://github.com/your-username/whatsapp-command-center/issues"
  },
  "homepage": "https://github.com/your-username/whatsapp-command-center#readme",
  "main": "src/index.js",
  "bin": {
    "whatsappCC": "bin/whatsappCC.js"
  },
  "files": [
    "bin",
    "src",
    "README.md"
  ],
  "scripts": {
    "start": "node src/index.js",
    "test": "node --test",
    "tauri": "tauri",
