{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "WhatsApp Command Center",
  "version": "1.0.2",
  "identifier": "com.whatsappcommandcenter.desktop",
  "build": {
    "beforeDevCommand": "npm run desktop:prepare",
    "beforeBuildCommand": "npm run desktop:prepare",
    "frontendDist": "../desktop"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "WhatsApp Command Center",
        "width": 1280,
        "height": 820,
        "minWidth": 900,
        "minHeight": 620,
        "url": "index.html"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "externalBin": [
      "binaries/wacc-node"
    ],
    "resources": [
      "resources/backend/"
    ]
  }
}
