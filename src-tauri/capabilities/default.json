{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default desktop permissions",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "binaries/wacc-node",
          "sidecar": true
        }
      ]
    },
    {
      "identifier": "shell:allow-open",
      "allow": [
        {
          "path": "http://127.0.0.1:*"
        },
        {
          "path": "http://localhost:*"
        }
      ]
    }
  ]
}
